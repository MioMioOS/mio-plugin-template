{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "MioIsland Sound Plugin",
  "description": "Schema for MioIsland sound plugins",
  "type": "object",
  "required": ["type", "id", "name", "version", "author", "price", "description", "tags", "preview", "category", "sounds"],
  "properties": {
    "type": {
      "const": "sound"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "github": { "type": "string" }
      },
      "additionalProperties": false
    },
    "price": {
      "type": "integer",
      "minimum": 0
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "preview": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": ["music", "notification", "ambient"]
    },
    "sounds": {
      "type": "object",
      "properties": {
        "session_start": {
          "type": "string",
          "pattern": "\\.(m4a|mp3)$",
          "description": "Audio file for agent session start"
        },
        "needs_approval": {
          "type": "string",
          "pattern": "\\.(m4a|mp3)$",
          "description": "Audio file for agent needs approval"
        },
        "session_complete": {
          "type": "string",
          "pattern": "\\.(m4a|mp3)$",
          "description": "Audio file for agent session complete"
        },
        "error": {
          "type": "string",
          "pattern": "\\.(m4a|mp3)$",
          "description": "Audio file for agent error"
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    }
  },
  "additionalProperties": false
}
